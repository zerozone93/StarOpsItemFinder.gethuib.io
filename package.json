{
  "name": "star-ops-item-finder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c cyan,blue \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.mjs",
    "build": "tsc -b && vite build",
    "sync:catalog": "node scripts/sync-star-citizen-catalog.mjs",
    "import:sources": "node scripts/import-sources.mjs",
    "export:json": "node scripts/export-json.mjs",
    "export:split": "node scripts/export-split-json.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "preview": "vite preview",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.1"
  }
}